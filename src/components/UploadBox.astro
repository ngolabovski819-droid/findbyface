---
const GOOGLE_AUTH_URL = `https://sirudrqheimbgpkchtwi.supabase.co/auth/v1/authorize?provider=google&redirect_to=${encodeURIComponent('https://findbyface.org/auth/callback')}`;
---

<!-- Terms of Use Modal -->
<div id="termsModal" class="auth-modal" style="display:none" role="dialog" aria-modal="true" aria-labelledby="termsTitle">
  <div class="auth-backdrop" id="termsBackdrop"></div>
  <div class="auth-box terms-box">
    <button class="auth-close" id="termsClose" aria-label="Close">×</button>
    <h3 id="termsTitle">User Agreement and Terms of Use</h3>
    <p class="terms-intro">By using our image search feature, I confirm that:</p>
    <div class="terms-scroll">
      <ul class="terms-list">
        <li>I am at least <strong>18 years of age</strong> or older</li>
        <li><strong>NOT</strong> use search results to approach or confront individuals</li>
        <li><strong>NOT</strong> engage in harassment of any person identified in search results</li>
        <li><strong>NEVER</strong> upload images of minors (under 18 years of age)</li>
        <li><strong>NOT</strong> follow, monitor, or stalk any individual</li>
        <li><strong>NOT</strong> attempt to extort, threaten, or blackmail any person</li>
        <li><strong>NOT</strong> utilize any information in ways that would require findbyface to obtain special licensing or reporting status with government entities</li>
        <li><strong>NOT</strong> use search results for employment screening, housing decisions, lending evaluations, or insurance assessments</li>
        <li><strong>NOT</strong> employ this service for any illegal purpose or activity</li>
        <li>I confirm I am <strong>NOT</strong> a resident or citizen of any European Union country</li>
        <li>I confirm full compliance with all laws and regulations applicable in my jurisdiction</li>
        <li>I acknowledge that my jurisdiction permits the use of facial recognition search technology</li>
      </ul>
      <p class="terms-section"><strong>Accuracy Disclaimer:</strong> findbyface provides no guarantees regarding the accuracy, reliability, or completeness of information presented on this website. All search results and content are provided "as is" without any warranty of any kind.</p>
      <p class="terms-section"><strong>Comprehensive Liability Release:</strong> By using this service, I hereby fully and permanently release, waive, and discharge findbyface, along with its parent organization, affiliated companies, subsidiaries, owners, investors, executives, directors, staff members, contractors, and representatives from any and all claims, liabilities, actions, demands, damages, costs, losses, legal proceedings, and judgments of any nature whatsoever, whether currently known or discovered in the future, that may arise from or relate to my use of findbyface services, including but not limited to search results, content accuracy, or data processing. I explicitly waive any legal rights or protections under any jurisdiction's laws that might otherwise limit the scope or effectiveness of this comprehensive release.</p>
      <p class="terms-section">By clicking "Agree and Search," I acknowledge that I have read, understood, and consent to be legally bound by all terms outlined above.</p>
    </div>
    <label class="terms-check-label">
      <input type="checkbox" id="termsCheckbox" />
      I understand and agree to the terms
    </label>
    <div class="terms-actions">
      <button class="terms-cancel-btn" id="termsCancelBtn">Cancel</button>
      <button class="terms-agree-btn" id="termsAgreeBtn" disabled>Agree and Search</button>
    </div>
  </div>
</div>

<!-- Auth Gate Modal -->
<div id="authModal" class="auth-modal" style="display:none" role="dialog" aria-modal="true">
  <div class="auth-backdrop" id="authBackdrop"></div>
  <div class="auth-box">
    <button class="auth-close" id="authClose" aria-label="Close">×</button>
    <div class="auth-icon-wrap">🔍</div>
    <h3>You've used your 2 free searches</h3>
    <p>Sign in free to unlock unlimited searches and see all matching profiles.</p>
    <a href={GOOGLE_AUTH_URL} class="google-btn">
      <svg viewBox="0 0 24 24" width="20" height="20" style="flex-shrink:0" aria-hidden="true">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Continue with Google — it's free
    </a>
    <button class="auth-skip" id="authSkip">Maybe later</button>
  </div>
</div>

<div class="upload-section">
  <div class="upload-box" id="uploadBox">

    <!-- State 1: Idle -->
    <div id="uploadIdle" class="upload-idle">
      <svg class="upload-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <h3>Drop a photo here</h3>
      <p>Upload any image — we'll find creators who look just like them</p>
      <button class="choose-btn" id="chooseBtn">Choose photo</button>
      <input type="file" id="fileInput" accept="image/jpeg,image/png,image/webp" style="display:none" aria-label="Upload photo" />
      <p class="upload-hint">JPG · PNG · WEBP &nbsp;·&nbsp; Ctrl+V to paste</p>
    </div>

    <!-- State 2: Scanning -->
    <div id="uploadScanning" style="display:none" class="scanning-state">
      <div class="scanning-img-box">
        <img id="scanningImg" alt="Your photo being analyzed" />
        <div class="scan-line"></div>
      </div>
      <p class="scanning-title">findbyface is searching...</p>
      <p class="scanning-sub">Analyzing your image and comparing with millions of profiles to find lookalikes.</p>
      <div class="progress-track">
        <div class="progress-fill" id="progressFill"></div>
      </div>
      <p class="progress-pct" id="progressPct">0%</p>
    </div>

    <!-- State 3: Done -->
    <div id="uploadDone" style="display:none" class="done-state">
      <img id="thumbnailImg" class="thumbnail-img" alt="Searched photo" />
      <div class="done-info">
        <p class="done-label">Searched image</p>
        <button class="new-search-btn" id="newSearchBtn">← New Search</button>
      </div>
    </div>

  </div>

  <p class="upload-error" id="uploadError" style="display:none"></p>
  <div class="search-divider"><span>— or search by name —</span></div>
  <form class="search-bar-inline" action="/onlyfans-search/" method="get">
    <input type="text" name="q" placeholder="Search creators..." autocomplete="off" />
    <button type="submit">Search</button>
  </form>
</div>

<!-- Results -->
<div id="faceResults" class="face-results" style="display:none">
  <h2 class="results-heading">Matching Creators</h2>
  <div id="faceResultsGrid" class="face-results-grid"></div>
  <div id="unlockBanner" class="unlock-banner" style="display:none">
    <p id="unlockBannerText">🔒 <strong>8 more matches found</strong> — sign in free to see all</p>
    <a href={GOOGLE_AUTH_URL} class="unlock-banner-btn">Sign in with Google</a>
  </div>
</div>

<script>
  const GOOGLE_AUTH_URL = `https://sirudrqheimbgpkchtwi.supabase.co/auth/v1/authorize?provider=google&redirect_to=${encodeURIComponent('https://findbyface.org/auth/callback')}`;

  const uploadBox       = document.getElementById('uploadBox')!;
  const fileInput       = document.getElementById('fileInput') as HTMLInputElement;
  const chooseBtn       = document.getElementById('chooseBtn')!;
  const uploadIdle      = document.getElementById('uploadIdle')!;
  const uploadScanning  = document.getElementById('uploadScanning')!;
  const uploadDone      = document.getElementById('uploadDone')!;
  const scanningImg     = document.getElementById('scanningImg') as HTMLImageElement;
  const thumbnailImg    = document.getElementById('thumbnailImg') as HTMLImageElement;
  const progressFill    = document.getElementById('progressFill')!;
  const progressPct     = document.getElementById('progressPct')!;
  const uploadError     = document.getElementById('uploadError')!;
  const faceResults     = document.getElementById('faceResults')!;
  const faceResultsGrid = document.getElementById('faceResultsGrid')!;
  const newSearchBtn    = document.getElementById('newSearchBtn')!;
  const authModal       = document.getElementById('authModal')!;
  const authBackdrop    = document.getElementById('authBackdrop')!;
  const authClose       = document.getElementById('authClose')!;
  const authSkip        = document.getElementById('authSkip')!;
  const unlockBanner    = document.getElementById('unlockBanner')!;
  const unlockBannerText = document.getElementById('unlockBannerText')!;

  function isSignedIn(): boolean {
    try { return !!JSON.parse(localStorage.getItem('fbf_user') || 'null'); } catch { return false; }
  }
  function getSearchCount(): number {
    return parseInt(localStorage.getItem('fbf_searches') || '0');
  }
  function incrementSearchCount(): void {
    if (!isSignedIn()) localStorage.setItem('fbf_searches', String(getSearchCount() + 1));
  }
  function showAuthModal(): void { authModal.style.display = 'flex'; }
  function hideAuthModal(): void { authModal.style.display = 'none'; }

  authBackdrop.addEventListener('click', hideAuthModal);
  authClose.addEventListener('click', hideAuthModal);
  authSkip.addEventListener('click', hideAuthModal);

  // ── Terms modal ──────────────────────────────────────────────────────────
  const termsModal     = document.getElementById('termsModal')!;
  const termsBackdrop  = document.getElementById('termsBackdrop')!;
  const termsClose     = document.getElementById('termsClose')!;
  const termsCheckbox  = document.getElementById('termsCheckbox') as HTMLInputElement;
  const termsAgreeBtn  = document.getElementById('termsAgreeBtn') as HTMLButtonElement;
  const termsCancelBtn = document.getElementById('termsCancelBtn')!;

  const TERMS_KEY = 'fbf_terms_agreed';
  let _pendingFile: File | null = null;

  function hasAgreedToTerms(): boolean {
    return sessionStorage.getItem(TERMS_KEY) === '1';
  }

  function showTermsModal(file: File): void {
    _pendingFile = file;
    termsCheckbox.checked = false;
    termsAgreeBtn.disabled = true;
    termsModal.style.display = 'flex';
  }

  function hideTermsModal(): void {
    termsModal.style.display = 'none';
    _pendingFile = null;
  }

  termsCheckbox.addEventListener('change', () => {
    termsAgreeBtn.disabled = !termsCheckbox.checked;
  });

  termsAgreeBtn.addEventListener('click', () => {
    if (!termsCheckbox.checked) return;
    sessionStorage.setItem(TERMS_KEY, '1');
    termsModal.style.display = 'none';
    if (_pendingFile) { const f = _pendingFile; _pendingFile = null; handleFile(f); }
  });

  termsCancelBtn.addEventListener('click', hideTermsModal);
  termsBackdrop.addEventListener('click', hideTermsModal);
  termsClose.addEventListener('click', hideTermsModal);

  function gatedFileOpen(file: File): void {
    if (hasAgreedToTerms()) { handleFile(file); } else { showTermsModal(file); }
  }

  // ── Upload triggers ───────────────────────────────────────────────────────
  chooseBtn.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', () => { if (fileInput.files?.[0]) gatedFileOpen(fileInput.files[0]); });
  uploadBox.addEventListener('dragover', e => { e.preventDefault(); uploadBox.classList.add('drag-over'); });
  uploadBox.addEventListener('dragleave', () => uploadBox.classList.remove('drag-over'));
  uploadBox.addEventListener('drop', e => {
    e.preventDefault(); uploadBox.classList.remove('drag-over');
    const file = (e as DragEvent).dataTransfer?.files[0];
    if (file?.type.startsWith('image/')) gatedFileOpen(file);
  });
  document.addEventListener('paste', e => {
    const file = e.clipboardData?.files[0];
    if (file?.type.startsWith('image/')) gatedFileOpen(file);
  });
  newSearchBtn.addEventListener('click', () => {
    uploadDone.style.display = 'none';
    uploadIdle.style.display = 'flex';
    faceResults.style.display = 'none';
    uploadError.style.display = 'none';
    fileInput.value = '';
  });

  let progressTimer: ReturnType<typeof setInterval> | null = null;
  let _faceapi: any = null;
  let _modelsLoaded = false;

  function setProgressLabel(text: string): void {
    const sub = document.querySelector('.scanning-sub') as HTMLElement | null;
    if (sub) sub.textContent = text;
  }
  function startProgress(maxPct = 87): void {
    let pct = 0;
    progressFill.style.width = '0%';
    progressPct.textContent = '0%';
    progressTimer = setInterval(() => {
      pct = Math.min(pct + Math.random() * 5 + 1, maxPct);
      progressFill.style.width = `${pct}%`;
      progressPct.textContent = `${Math.round(pct)}%`;
    }, 200);
  }
  function finishProgress(): void {
    if (progressTimer) { clearInterval(progressTimer); progressTimer = null; }
    progressFill.style.width = '100%';
    progressPct.textContent = '100%';
  }

  async function loadFaceApi(): Promise<any> {
    if (_faceapi) return _faceapi;
    // Dynamic import of face-api.js from the installed package (Astro bundles it)
    // @ts-ignore
    const mod = await import('/node_modules/@vladmandic/face-api/dist/face-api.esm.js');
    _faceapi = mod.default ?? mod;
    return _faceapi;
  }

  async function ensureModels(faceapi: any): Promise<void> {
    if (_modelsLoaded) return;
    await Promise.all([
      faceapi.nets.ssdMobilenetv1.loadFromUri('/models'),
      faceapi.nets.faceLandmark68Net.loadFromUri('/models'),
      faceapi.nets.faceRecognitionNet.loadFromUri('/models'),
    ]);
    _modelsLoaded = true;
  }

  async function detectDescriptor(faceapi: any, img: HTMLImageElement): Promise<Float32Array | null> {
    const result = await faceapi
      .detectSingleFace(img, new faceapi.SsdMobilenetv1Options({ minConfidence: 0.4 }))
      .withFaceLandmarks()
      .withFaceDescriptor();
    return result?.descriptor ?? null;
  }

  async function handleFile(file: File): Promise<void> {
    if (!isSignedIn() && getSearchCount() >= 2) { showAuthModal(); return; }
    uploadError.style.display = 'none';

    const dataUrl = await new Promise<string>((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = ev => resolve(String(ev.target?.result ?? ''));
      reader.onerror = reject;
      reader.readAsDataURL(file);
    });

    scanningImg.src = dataUrl;
    thumbnailImg.src = dataUrl;
    uploadIdle.style.display = 'none';
    uploadScanning.style.display = 'flex';

    try {
      // Phase 1: load models (up to 40%)
      setProgressLabel('Loading face detection models...');
      startProgress(40);
      const faceapi = await loadFaceApi();
      await ensureModels(faceapi);

      // Phase 2: detect face in image (40→75%)
      setProgressLabel('Detecting face...');
      if (progressTimer) clearInterval(progressTimer);
      progressTimer = null;
      let pct = 40;
      progressTimer = setInterval(() => {
        pct = Math.min(pct + 3, 75);
        progressFill.style.width = `${pct}%`;
        progressPct.textContent = `${Math.round(pct)}%`;
      }, 150);

      const img = new Image();
      img.src = dataUrl;
      await new Promise<void>((res, rej) => { img.onload = () => res(); img.onerror = () => rej(); });
      const descriptor = await detectDescriptor(faceapi, img);

      if (!descriptor) {
        finishProgress();
        uploadScanning.style.display = 'none';
        uploadIdle.style.display = 'flex';
        uploadError.textContent = 'No face detected — try a clearer, well-lit photo';
        uploadError.style.display = 'block';
        return;
      }

      // Phase 3: search API (75→100%)
      setProgressLabel('Searching for lookalikes...');
      if (progressTimer) clearInterval(progressTimer);
      pct = 75;
      progressTimer = setInterval(() => {
        pct = Math.min(pct + 4, 97);
        progressFill.style.width = `${pct}%`;
        progressPct.textContent = `${Math.round(pct)}%`;
      }, 180);

      const resp = await fetch('/api/face-search', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ descriptor: Array.from(descriptor) }),
      });
      if (!resp.ok) throw new Error('API error');
      const data = await resp.json();

      finishProgress();
      incrementSearchCount();
      await new Promise(r => setTimeout(r, 400));
      uploadScanning.style.display = 'none';
      uploadDone.style.display = 'flex';
      setProgressLabel('Analyzing your image and comparing with millions of profiles to find lookalikes.');
      showResults(data.results ?? []);
    } catch (err) {
      finishProgress();
      uploadScanning.style.display = 'none';
      uploadIdle.style.display = 'flex';
      setProgressLabel('Analyzing your image and comparing with millions of profiles to find lookalikes.');
      uploadError.textContent = 'Search failed — please try again';
      uploadError.style.display = 'block';
    }
  }

  function proxyImg(url: string, w: number, h: number): string {
    if (!url || url.startsWith('/')) return url;
    return `https://images.weserv.nl/?url=${encodeURIComponent(url.replace(/^https?:\/\//, ''))}&w=${w}&h=${h}&fit=cover&output=webp`;
  }

  function renderCard(c: Record<string, unknown>, index: number, signedIn: boolean): string {
    const imgSrc = (c.avatar as string)?.startsWith('http') ? proxyImg(c.avatar as string, 320, 427) : '/no-image.png';
    const price = (c.subscribePrice ?? c.subscribeprice) as number;
    const priceLabel = (!price || isNaN(Number(price))) ? 'FREE' : `$${parseFloat(String(price)).toFixed(2)}`;
    const matchPct = c.matchPct != null ? (c.matchPct as number) : null;
    const matchBadge = matchPct != null && matchPct > 0 ? `<span class="match-badge">${matchPct}% match</span>` : '';
    const profileUrl = `https://onlyfans.com/${encodeURIComponent(c.username as string)}`;
    const locked = !signedIn && index >= 4;

    if (locked) {
      return `<div class="creator-card locked">
        <div class="card-img-wrap">
          <img src="${imgSrc}" alt="Locked creator" loading="lazy" decoding="async" referrerpolicy="no-referrer"
            style="filter:blur(10px);transform:scale(1.08);"
            onerror="if(this.src!=='/no-image.png'){this.src='/no-image.png';}">
          ${matchBadge}
          <div class="lock-overlay" onclick="document.getElementById('authModal').style.display='flex'">
            <button class="unlock-btn">🔓 Unlock</button>
          </div>
        </div>
        <div class="card-body locked-body">
          <p class="creator-name">••••• •••••</p>
          <p class="username">@••••••••</p>
          <p class="price">${priceLabel}</p>
          <div class="view-btn-locked">View Profile</div>
        </div>
      </div>`;
    }

    return `<div class="creator-card">
      <div class="card-img-wrap">
        <img src="${imgSrc}" alt="${(c.name || c.username) as string}" loading="${index === 0 ? 'eager' : 'lazy'}"
          decoding="async" referrerpolicy="no-referrer"
          onerror="if(this.src!=='/no-image.png'){this.src='/no-image.png';}">
        ${matchBadge}
      </div>
      <div class="card-body">
        <p class="creator-name">${(c.name || c.username) as string}</p>
        <p class="username">@${c.username as string}</p>
        <p class="price ${priceLabel === 'FREE' ? 'price-free' : ''}">${priceLabel}</p>
        <a href="${profileUrl}" class="view-btn" target="_blank" rel="noopener noreferrer">View Profile</a>
      </div>
    </div>`;
  }

  function showResults(results: Record<string, unknown>[]): void {
    const signedIn = isSignedIn();
    faceResultsGrid.innerHTML = results.map((c, i) => renderCard(c, i, signedIn)).join('');
    faceResults.style.display = 'block';
    if (!signedIn && results.length > 4) {
      const locked = results.length - 4;
      unlockBannerText.innerHTML = `🔒 <strong>${locked} more matches found</strong> — sign in free to see all`;
      unlockBanner.style.display = 'flex';
    } else {
      unlockBanner.style.display = 'none';
    }
    faceResults.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
</script>

<style>
  .auth-modal {
    position: fixed; inset: 0; z-index: 9999;
    display: flex; align-items: center; justify-content: center;
  }
  .auth-backdrop {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
  }
  .auth-box {
    position: relative; z-index: 1;
    background: var(--surface-raised); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 40px 32px;
    max-width: 420px; width: 90%; text-align: center;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }
  /* Terms modal overrides */
  .terms-box {
    max-width: 560px; text-align: left; padding: 32px 28px 28px;
  }
  .terms-box h3 { font-size: 1.2rem; margin-bottom: 8px; }
  .terms-intro { font-size: 13px; color: var(--text-muted); margin-bottom: 12px; }
  .terms-scroll {
    max-height: 320px; overflow-y: auto; border: 1px solid var(--border);
    border-radius: 8px; padding: 14px 16px; margin-bottom: 16px;
    font-size: 13px; line-height: 1.65; color: var(--text);
    scrollbar-width: thin; scrollbar-color: var(--accent) transparent;
  }
  .terms-list {
    padding-left: 18px; margin-bottom: 14px;
  }
  .terms-list li { margin-bottom: 7px; }
  .terms-section { margin-bottom: 12px; }
  .terms-check-label {
    display: flex; align-items: center; gap: 10px;
    font-size: 14px; cursor: pointer; margin-bottom: 18px;
    color: var(--text);
  }
  .terms-check-label input[type="checkbox"] {
    width: 18px; height: 18px; accent-color: var(--accent); cursor: pointer; flex-shrink: 0;
  }
  .terms-actions {
    display: flex; gap: 10px; justify-content: flex-end;
  }
  .terms-cancel-btn {
    padding: 10px 20px; border-radius: 8px; font-size: 14px; font-weight: 600;
    border: 1px solid var(--border); background: transparent;
    color: var(--text-muted); cursor: pointer; transition: color 0.2s;
  }
  .terms-cancel-btn:hover { color: var(--text); }
  .terms-agree-btn {
    padding: 10px 22px; border-radius: 8px; font-size: 14px; font-weight: 600;
    border: none; background: var(--accent); color: #fff;
    cursor: pointer; transition: background 0.2s, opacity 0.2s;
  }
  .terms-agree-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .terms-agree-btn:not(:disabled):hover { background: var(--accent-light); }
  .auth-close {
    position: absolute; top: 14px; right: 16px;
    background: none; border: none; color: var(--text-muted);
    font-size: 24px; cursor: pointer; line-height: 1; padding: 2px 6px;
  }
  .auth-close:hover { color: var(--text); }
  .auth-icon-wrap { font-size: 40px; margin-bottom: 16px; }
  .auth-box h3 { font-size: 1.3rem; margin-bottom: 10px; }
  .auth-box p { color: var(--text-muted); font-size: 14px; line-height: 1.6; margin-bottom: 24px; }
  .google-btn {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    background: #fff; color: #1f1f1f; border-radius: 999px;
    padding: 13px 24px; font-size: 15px; font-weight: 600;
    text-decoration: none; transition: box-shadow 0.2s; margin-bottom: 12px;
  }
  .google-btn:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.3); }
  .auth-skip {
    background: none; border: none; color: var(--text-muted);
    font-size: 13px; cursor: pointer; padding: 6px;
    font-family: inherit; text-decoration: underline; transition: color 0.2s;
  }
  .auth-skip:hover { color: var(--text); }

  .upload-section {
    display: flex; flex-direction: column;
    align-items: center; gap: 20px; padding: 0 20px; width: 100%;
