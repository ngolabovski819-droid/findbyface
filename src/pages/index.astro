---
import Base from '../layouts/Base.astro';
import UploadBox from '../components/UploadBox.astro';
import StatsBar from '../components/StatsBar.astro';
import CategoryChips from '../components/CategoryChips.astro';
import CreatorCard from '../components/CreatorCard.astro';

const SUPABASE_URL = import.meta.env.SUPABASE_URL?.replace(/\/+$/, '');
const SUPABASE_KEY = import.meta.env.SUPABASE_KEY;

let initialCreators: any[] = [];
let hasMore = false;

if (SUPABASE_URL && SUPABASE_KEY) {
  try {
    const params = new URLSearchParams({
      select: 'id,username,name,avatar,isverified,subscribeprice,favoritedcount',
      order:  'favoritedcount.desc',
      limit:  '20',
    });
    const resp = await fetch(`${SUPABASE_URL}/rest/v1/onlyfans_profiles?${params}`, {
      headers: {
        apikey: SUPABASE_KEY,
        Authorization: `Bearer ${SUPABASE_KEY}`,
        'Accept-Profile': 'public',
        Prefer: 'count=estimated',
      },
    });
    if (resp.ok) {
      const raw = await resp.json();
      const cr = resp.headers.get('Content-Range') ?? '';
      const total = parseInt(cr.split('/')[1] ?? '0') || 0;
      hasMore = total > 20;
      initialCreators = raw.map((c: Record<string, unknown>) => ({
        id:             c.id,
        username:       c.username,
        name:           c.name,
        avatar:         c.avatar,
        isVerified:     c.isverified,
        subscribePrice: c.subscribeprice,
      }));
    }
  } catch { /* serve page without initial creators */ }
}
---

<Base title="findbyface — Find Lookalike OnlyFans Creators Instantly">
  <div class="hero">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      AI-powered face matching
    </div>
    <h1><span class="h1-white">Find</span> <span class="gradient-text">lookalike</span><br /><span class="h1-white">creators instantly</span></h1>
    <p class="hero-sub">Upload a photo and discover OnlyFans creators with similar appearances in seconds.</p>
  </div>

  <UploadBox />

  <StatsBar />

  <section class="browse-section">
    <h2 class="section-title">Browse by Category</h2>
    <CategoryChips />
  </section>

  {initialCreators.length > 0 && (
    <section class="creators-section">
      <h2 class="section-title">Popular Creators</h2>
      <div class="creators-grid" id="creatorsGrid">
        {initialCreators.map((c, i) => <CreatorCard creator={c} index={i} />)}
      </div>
      {hasMore && (
        <div class="load-more-wrap">
          <button class="load-more-btn" id="loadMoreBtn">Load More</button>
        </div>
      )}
    </section>
  )}
</Base>

<script>
  let currentPage = 2;
  let isLoading = false;
  let hasMoreResults = true;

  const loadMoreBtn = document.getElementById('loadMoreBtn');
  const grid = document.getElementById('creatorsGrid');

  function proxyImg(url: string, w: number, h: number): string {
    if (!url || url.startsWith('/')) return url;
    return `https://images.weserv.nl/?url=${encodeURIComponent(url.replace(/^https?:\/\//, ''))}&w=${w}&h=${h}&fit=cover&output=webp`;
  }

  function renderCard(c: any): string {
    const imgSrc = c.avatar?.startsWith('http') ? proxyImg(c.avatar, 320, 427) : '/no-image.png';
    const price = c.subscribePrice ?? c.subscribeprice;
    const priceLabel = (!price || isNaN(price)) ? 'FREE' : `$${parseFloat(price).toFixed(2)}`;
    const profileUrl = `https://onlyfans.com/${encodeURIComponent(c.username)}`;
    return `<div class="creator-card">
      <div class="card-img-wrap">
        <img src="${imgSrc}" alt="${c.name || c.username}" loading="lazy" decoding="async"
          referrerpolicy="no-referrer"
          onerror="if(this.src!=='/no-image.png'){this.removeAttribute('srcset');this.src='/no-image.png';}">
      </div>
      <div class="card-body">
        <p class="creator-name">${c.name || c.username}</p>
        <p class="username">@${c.username}</p>
        <p class="price ${priceLabel === 'FREE' ? 'price-free' : ''}">${priceLabel}</p>
        <a href="${profileUrl}" class="view-btn" target="_blank" rel="noopener">View Profile</a>
      </div>
    </div>`;
  }

  loadMoreBtn?.addEventListener('click', async () => {
    if (isLoading || !hasMoreResults) return;
    isLoading = true;
    loadMoreBtn.textContent = 'Loading...';
    (loadMoreBtn as HTMLButtonElement).disabled = true;

    try {
      const resp = await fetch(`/api/search?page=${currentPage}&page_size=20`);
      const data = await resp.json();
      data.creators?.forEach((c: any) => grid?.insertAdjacentHTML('beforeend', renderCard(c)));
      hasMoreResults = data.hasMore;
      currentPage++;
      loadMoreBtn.textContent = 'Load More';
      (loadMoreBtn as HTMLButtonElement).disabled = false;
      if (!hasMoreResults) (loadMoreBtn as HTMLElement).style.display = 'none';
    } catch {
      loadMoreBtn.textContent = 'Load More';
      (loadMoreBtn as HTMLButtonElement).disabled = false;
    }
    isLoading = false;
  });
</script>

<style>
  .hero {
    text-align: center;
    padding: 100px 20px 48px;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(124,58,237,0.15);
    border: 1px solid rgba(124,58,237,0.3);
    border-radius: 999px;
    padding: 6px 16px;
    font-size: 13px;
    color: var(--accent-light);
    margin-bottom: 28px;
  }

  .badge-dot {
    width: 6px; height: 6px;
    background: var(--accent-light);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero h1 {
    font-size: clamp(2.4rem, 6vw, 4rem);
    line-height: 1.1;
    margin-bottom: 20px;
  }

  .h1-white {
    color: #ffffff;
  }

  .gradient-text {
    background: linear-gradient(135deg, #7c3aed, #ec4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .browse-section,
  .creators-section {
    max-width: 1200px;
    margin: 64px auto 0;
    padding: 0 20px;
  }

  .section-title {
    font-size: 1.4rem;
    margin-bottom: 24px;
  }

  .creators-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  @media (max-width: 900px) { .creators-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 600px) { .creators-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; } }

  .load-more-wrap {
    display: flex;
    justify-content: center;
    margin-top: 40px;
  }

  .load-more-btn {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text);
    padding: 12px 44px;
    border-radius: 999px;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: all 0.2s;
  }

  .load-more-btn:hover { border-color: var(--accent); color: var(--accent); }

  /* Card styles for JS load-more */
  .creator-card { background: var(--surface); border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--border); transition: transform 0.2s, box-shadow 0.2s; }
  .creator-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px var(--accent-glow); }
  .card-img-wrap { aspect-ratio: 3/4; overflow: hidden; background: var(--surface-raised); }
  .card-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .card-body { padding: 12px 14px; }
  .creator-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .username { color: var(--text-muted); font-size: 12px; margin-bottom: 6px; }
  .price { font-weight: 700; font-size: 15px; margin-bottom: 10px; color: var(--text-muted); }
  .price-free { color: var(--success); }
  .view-btn { display: block; text-align: center; background: var(--accent); color: #fff; border-radius: 8px; padding: 8px; font-size: 13px; font-weight: 600; transition: background 0.2s; }
  .view-btn:hover { background: var(--accent-light); }
</style>
