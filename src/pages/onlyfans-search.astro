---
import Base from '../layouts/Base.astro';

const q        = Astro.url.searchParams.get('q') ?? '';
const verified = Astro.url.searchParams.get('verified') ?? '';
const price    = Astro.url.searchParams.get('price') ?? '';
const sort     = Astro.url.searchParams.get('sort') ?? '';
---

<Base
  title="OnlyFans Search Engine | findbyface"
  description="Search millions of OnlyFans creators with advanced filters. Filter by verified status, price, bundles and more."
>
  <div class="search-page">
    <div class="search-header">
      <h1>OnlyFans Search Engine</h1>
      <p class="search-sub">Search and filter from millions of creators</p>
    </div>

    <div class="search-layout">
      <aside class="filters">
        <h3 class="filters-title">Filters</h3>

        <div class="filter-group">
          <label class="filter-label" for="searchInput">Search</label>
          <input type="text" id="searchInput" placeholder="Search creators..." value={q} autocomplete="off" />
        </div>

        <div class="filter-group">
          <label class="filter-label toggle-label">
            <span>Verified only</span>
            <label class="toggle">
              <input type="checkbox" id="verifiedToggle" checked={verified === 'true'} />
              <span class="toggle-slider"></span>
            </label>
          </label>
        </div>

        <div class="filter-group">
          <span class="filter-label">Price</span>
          <div class="pill-group" id="priceOptions">
            {(['', '0', '5', '10'] as const).map(p => (
              <button class={`pill ${price === p ? 'active' : ''}`} data-price={p}>
                {p === '' ? 'Any' : p === '0' ? 'Free' : `Under $${p}`}
              </button>
            ))}
          </div>
        </div>

        <div class="filter-group">
          <span class="filter-label">Sort</span>
          <div class="pill-group" id="sortOptions">
            <button class={`pill ${sort !== 'newest' ? 'active' : ''}`} data-sort="">Popular</button>
            <button class={`pill ${sort === 'newest' ? 'active' : ''}`} data-sort="newest">Newest</button>
          </div>
        </div>

        <div class="filter-group">
          <label class="filter-label toggle-label">
            <span>Has bundles</span>
            <label class="toggle">
              <input type="checkbox" id="bundlesToggle" />
              <span class="toggle-slider"></span>
            </label>
          </label>
        </div>

        <button class="apply-btn" id="applyBtn">Apply Filters</button>
      </aside>

      <div class="results-area">
        <p class="results-meta" id="resultsCount">Loading...</p>
        <div class="results-grid" id="resultsGrid"></div>
        <div class="load-more-wrap" id="loadMoreWrap" style="display:none">
          <button class="load-more-btn" id="loadMoreBtn">Load More</button>
        </div>
      </div>
    </div>
  </div>
</Base>

<script>
  let currentPage = 1;
  let isLoading = false;
  let hasMoreResults = false;

  const qs = new URLSearchParams(window.location.search);
  let activeFilters = {
    q:        qs.get('q') ?? '',
    verified: qs.get('verified') ?? '',
    price:    qs.get('price') ?? '',
    sort:     qs.get('sort') ?? '',
    bundles:  '',
  };

  const searchInput    = document.getElementById('searchInput') as HTMLInputElement;
  const verifiedToggle = document.getElementById('verifiedToggle') as HTMLInputElement;
  const bundlesToggle  = document.getElementById('bundlesToggle') as HTMLInputElement;
  const resultsGrid    = document.getElementById('resultsGrid')!;
  const resultsCount   = document.getElementById('resultsCount')!;
  const loadMoreWrap   = document.getElementById('loadMoreWrap')!;
  const loadMoreBtn    = document.getElementById('loadMoreBtn') as HTMLButtonElement;
  const applyBtn       = document.getElementById('applyBtn')!;

  document.querySelectorAll('#priceOptions .pill').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#priceOptions .pill').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeFilters.price = (btn as HTMLElement).dataset.price ?? '';
    });
  });

  document.querySelectorAll('#sortOptions .pill').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#sortOptions .pill').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeFilters.sort = (btn as HTMLElement).dataset.sort ?? '';
    });
  });

  let debounceTimer: ReturnType<typeof setTimeout>;
  searchInput?.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      activeFilters.q = searchInput.value.trim();
      doSearch();
    }, 350);
  });

  applyBtn.addEventListener('click', () => {
    activeFilters.q        = searchInput?.value.trim() ?? '';
    activeFilters.verified = verifiedToggle?.checked ? 'true' : '';
    activeFilters.bundles  = bundlesToggle?.checked ? 'true' : '';
    doSearch();
  });

  loadMoreBtn.addEventListener('click', () => fetchCreators(true));

  function proxyImg(url: string, w: number, h: number): string {
    if (!url || url.startsWith('/')) return url;
    return `https://images.weserv.nl/?url=${encodeURIComponent(url.replace(/^https?:\/\//, ''))}&w=${w}&h=${h}&fit=cover&output=webp`;
  }

  function renderCard(c: any, index: number): string {
    const imgSrc = c.avatar?.startsWith('http') ? proxyImg(c.avatar, 320, 427) : '/no-image.png';
    const price = c.subscribePrice ?? c.subscribeprice;
    const priceLabel = (!price || isNaN(price)) ? 'FREE' : `$${parseFloat(price).toFixed(2)}`;
    const profileUrl = `https://onlyfans.com/${encodeURIComponent(c.username)}`;
    return `<div class="creator-card">
      <div class="card-img-wrap">
        <img src="${imgSrc}" alt="${c.name || c.username}" loading="${index < 8 ? 'eager' : 'lazy'}"
          decoding="async" referrerpolicy="no-referrer"
          onerror="if(this.src!=='/no-image.png'){this.removeAttribute('srcset');this.src='/no-image.png';}">
      </div>
      <div class="card-body">
        <p class="creator-name">${c.name || c.username}</p>
        <p class="username">@${c.username}</p>
        <p class="price ${priceLabel === 'FREE' ? 'price-free' : ''}">${priceLabel}</p>
        <a href="${profileUrl}" class="view-btn" target="_blank" rel="noopener">View Profile</a>
      </div>
    </div>`;
  }

  async function fetchCreators(append = false) {
    if (isLoading) return;
    isLoading = true;

    if (!append) {
      currentPage = 1;
      resultsGrid.innerHTML = '<p class="loading-msg">Loading...</p>';
    }

    loadMoreBtn.textContent = 'Loading...';
    loadMoreBtn.disabled = true;

    const params = new URLSearchParams();
    if (activeFilters.q)        params.set('q',        activeFilters.q);
    if (activeFilters.verified) params.set('verified',  activeFilters.verified);
    if (activeFilters.price)    params.set('price',     activeFilters.price);
    if (activeFilters.sort)     params.set('sort',      activeFilters.sort);
    if (activeFilters.bundles)  params.set('bundles',   activeFilters.bundles);
    params.set('page',      String(currentPage));
    params.set('page_size', '20');

    try {
      const resp = await fetch(`/api/search?${params}`);
      const data = await resp.json();

      if (!append) resultsGrid.innerHTML = '';
      if (!data.creators?.length && !append) {
        resultsGrid.innerHTML = '<p class="loading-msg">No creators found.</p>';
      } else {
        data.creators?.forEach((c: any, i: number) =>
          resultsGrid.insertAdjacentHTML('beforeend', renderCard(c, append ? 999 : i))
        );
      }

      hasMoreResults = data.hasMore;
      currentPage++;

      resultsCount.textContent = data.total
        ? `${data.total.toLocaleString()} creators found`
        : `${data.creators?.length ?? 0} results`;

      loadMoreWrap.style.display = hasMoreResults ? 'flex' : 'none';
      loadMoreBtn.textContent = 'Load More';
      loadMoreBtn.disabled = false;

      // sync ?q= into URL
      const urlObj = new URL(window.location.href);
      if (activeFilters.q) urlObj.searchParams.set('q', activeFilters.q);
      else urlObj.searchParams.delete('q');
      if (activeFilters.sort) urlObj.searchParams.set('sort', activeFilters.sort);
      else urlObj.searchParams.delete('sort');
      window.history.replaceState({}, '', urlObj.toString());
    } catch {
      resultsGrid.innerHTML = '<p class="loading-msg">Error loading results — please try again.</p>';
      loadMoreBtn.textContent = 'Load More';
      loadMoreBtn.disabled = false;
    }

    isLoading = false;
  }

  function doSearch() {
    currentPage = 1;
    fetchCreators(false);
  }

  // Initial load
  fetchCreators(false);
</script>

<style>
  .search-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 100px 20px 60px;
  }

  .search-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .search-header h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin-bottom: 12px; }
  .search-sub { color: var(--text-muted); }

  .search-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 32px;
  }

  .filters {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 24px;
    height: fit-content;
    position: sticky;
    top: 80px;
  }

  .filters-title { font-size: 1rem; margin-bottom: 24px; }
  .filter-group { margin-bottom: 22px; }

  .filter-label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .toggle-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    margin-bottom: 0;
  }

  .filter-group input[type="text"] {
    width: 100%;
    background: var(--surface-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 10px 12px;
    color: var(--text);
    font-size: 14px;
    font-family: 'Inter', sans-serif;
    outline: none;
    transition: border-color 0.2s;
  }

  .filter-group input[type="text"]:focus { border-color: var(--accent); }
  .filter-group input[type="text"]::placeholder { color: var(--text-muted); }

  .pill-group { display: flex; flex-wrap: wrap; gap: 6px; }

  .pill {
    padding: 6px 12px;
    background: var(--surface-raised);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 12px;
    color: var(--text-muted);
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: all 0.2s;
  }

  .pill.active { background: var(--accent); border-color: var(--accent); color: #fff; }

  .toggle { position: relative; display: inline-block; width: 40px; height: 22px; flex-shrink: 0; }
  .toggle input { opacity: 0; width: 0; height: 0; }
  .toggle-slider { position: absolute; inset: 0; background: var(--surface-raised); border-radius: 999px; cursor: pointer; transition: 0.3s; border: 1px solid var(--border); }
  .toggle-slider::before { content: ''; position: absolute; width: 14px; height: 14px; left: 3px; bottom: 3px; background: var(--text-muted); border-radius: 50%; transition: 0.3s; }
  .toggle input:checked + .toggle-slider { background: var(--accent); border-color: var(--accent); }
  .toggle input:checked + .toggle-slider::before { transform: translateX(18px); background: #fff; }

  .apply-btn {
    width: 100%;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: var(--radius);
    padding: 12px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    transition: background 0.2s;
  }

  .apply-btn:hover { background: var(--accent-light); }

  .results-meta { color: var(--text-muted); font-size: 14px; margin-bottom: 20px; }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .loading-msg { grid-column: 1 / -1; text-align: center; color: var(--text-muted); padding: 60px 0; }

  .load-more-wrap { display: flex; justify-content: center; margin-top: 40px; }

  .load-more-btn {
    background: transparent; border: 1px solid var(--border);
    color: var(--text); padding: 12px 44px; border-radius: 999px;
    font-size: 15px; font-weight: 500; cursor: pointer;
    font-family: 'Inter', sans-serif; transition: all 0.2s;
  }

  .load-more-btn:hover { border-color: var(--accent); color: var(--accent); }

  /* Card styles */
  .creator-card { background: var(--surface); border-radius: var(--radius-lg); overflow: hidden; border: 1px solid var(--border); transition: transform 0.2s, box-shadow 0.2s; }
  .creator-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px var(--accent-glow); }
  .card-img-wrap { aspect-ratio: 3/4; overflow: hidden; background: var(--surface-raised); }
  .card-img-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .card-body { padding: 12px 14px; }
  .creator-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px; margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .username { color: var(--text-muted); font-size: 12px; margin-bottom: 6px; }
  .price { font-weight: 700; font-size: 15px; margin-bottom: 10px; color: var(--text-muted); }
  .price-free { color: var(--success); }
  .view-btn { display: block; text-align: center; background: var(--accent); color: #fff; border-radius: 8px; padding: 8px; font-size: 13px; font-weight: 600; transition: background 0.2s; }
  .view-btn:hover { background: var(--accent-light); }

  @media (max-width: 1000px) {
    .search-layout { grid-template-columns: 1fr; }
    .filters { position: static; }
    .results-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 640px) { .results-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; } }
</style>
